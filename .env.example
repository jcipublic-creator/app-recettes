# --- Upstash Redis (REST API) ---
UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxx

# --- Cloudinary (medias) ---
CLOUDINARY_CLOUD_NAME=xxxxx
CLOUDINARY_API_KEY=xxxxx
CLOUDINARY_API_SECRET=xxxxx

# --- Securite ---
# Mot de passe pour acceder a l'administration (ajout/edition/suppression)
ADMIN_PASSWORD=change-moi
# Secret pour signer le cookie de session admin (chaine aleatoire longue)
SESSION_SECRET=change-moi-aussi-une-longue-chaine-aleatoire

# --- Serveur ---
PORT=3000
